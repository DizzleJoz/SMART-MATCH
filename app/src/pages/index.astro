---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import BottomNav from '../components/BottomNav.astro';
import CompanySwipeCard from '../components/CompanySwipeCard.astro';

// Sample data for company cards
const companies = [
  {
    companyName: "TechNova Inc.",
    jobTitle: "Diseñadora UX/UI Senior",
    sector: "Fintech",
    size: "50-200 personas",
    description: "Estamos revolucionando los pagos B2B. Buscamos talento apasionado por resolver problemas complejos con código limpio y escalable.",
    benefits: ["Trabajo remoto", "Equity", "Horario flexible"],
    matchScore: 94,
    logoImage: "https://images.unsplash.com/photo-1560179707-f14e90ef3623?w=150&h=150&fit=crop",
    coverImage: "https://images.unsplash.com/photo-1497366216548-37526070297c?w=600&h=400&fit=crop"
  },
  {
    companyName: "Luminary Studios",
    jobTitle: "Directora de Arte Digital",
    sector: "Agencia Creativa",
    size: "10-50 personas",
    description: "Creamos experiencias digitales galardonadas. Cultura relajada, enfocada en la creatividad y el diseño centrado en el usuario.",
    benefits: ["Oficina pet-friendly", "Viernes cortos", "Bonos"],
    matchScore: 88,
    logoImage: "https://images.unsplash.com/photo-1572044162444-ad60f128bdea?w=150&h=150&fit=crop",
    coverImage: "https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=600&h=400&fit=crop"
  },
  {
    companyName: "EcoLogistics",
    jobTitle: "Product Manager Mid",
    sector: "Green Tech",
    size: "200-500 personas",
    description: "Optimizamos la cadena de suministro global para reducir emisiones de carbono. Únete a nuestra misión por un futuro sostenible.",
    benefits: ["Seguro médico", "Remoto opcional", "Stock"],
    matchScore: 82,
    logoImage: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=150&h=150&fit=crop",
    coverImage: "https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=600&h=400&fit=crop"
  }
];
---

<Layout title="JobMatch | Descubre Empresas">
  <div class="relative w-full h-full flex flex-col bg-transparent overflow-hidden touch-none">
    
    <TopBar />

    <!-- Cards Stack -->
    <main class="flex-1 relative w-full flex items-center justify-center overflow-hidden" id="card-stack">
      {/* Render cards in reverse order */}
      <CompanySwipeCard 
        {...companies[2]}
        isThird={true}
      />
      <CompanySwipeCard 
        {...companies[1]}
        isSecond={true}
      />
      <CompanySwipeCard 
        {...companies[0]}
        isTop={true}
      />
    </main>

    <!-- Action Buttons -->
    <div class="absolute bottom-28 left-0 right-0 flex items-center justify-center gap-8 px-8 z-40 pointer-events-none">
      
      <!-- Reject (Swipe Left) -->
      <button id="btn-pass" class="w-20 h-20 rounded-full bg-white/10 border-2 border-white flex items-center justify-center text-white spring-transition hover:scale-[1.12] active:scale-[1.12] active:shadow-[0_0_20px_rgba(255,60,60,0.35)] pointer-events-auto backdrop-blur-md cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-8 h-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Match (Swipe Right) -->
      <button id="btn-match" class="w-20 h-20 rounded-full bg-[#FF8300] flex items-center justify-center text-white spring-transition hover:scale-[1.12] active:scale-[1.12] active:shadow-[0_0_20px_rgba(255,131,0,0.45)] pointer-events-auto shadow-lg cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-9 h-9">
          <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z" />
        </svg>
      </button>
      
    </div>
    
    <!-- Floating Help Button (Home Only) -->
    <button id="home-help-btn" class="absolute bottom-32 right-6 w-12 h-12 rounded-full bg-[#FF8300]/90 backdrop-blur-md text-white flex items-center justify-center shadow-[0_0_20px_rgba(255,131,0,0.4)] z-[60] spring-transition active:scale-90 hover:scale-110 cursor-pointer border border-white/10">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7">
        <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12zm11.378-3.917c-.734-1.127-2.316-1.353-3.322-.447a.75.75 0 101.01 1.109c.307-.28.847-.209 1.137.234.254.388.163.9-.196 1.182l-1.312.984a2.25 2.25 0 00-1.025 1.838V15a.75.75 0 001.5 0v-1.05c0-.18.067-.354.19-.48l1.312-.983a4.25 4.25 0 001.621-3.376c0-.024-.001-.048-.002-.072a.75.75 0 10-1.5-.182zm-2.003 7.667a.875.875 0 111.75 0 .875.875 0 01-1.75 0z" clip-rule="evenodd" />
      </svg>
    </button>

    <BottomNav activeTab="home" />
    
    <!-- Help Chat Modal -->
    <div id="help-chat-modal" class="fixed inset-0 z-[110] bg-[#010146]/80 backdrop-blur-sm flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
      <div class="w-full max-w-sm h-[500px] glass-card flex flex-col overflow-hidden shadow-2xl border border-white/10 mx-6 scale-95 transition-transform duration-300" id="help-chat-content">
        <!-- Chat Header -->
        <div class="p-4 bg-[#FF8300] flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center border border-white/30">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-white">
                <path fill-rule="evenodd" d="M7.5 6a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM3.751 20.105a8.25 8.25 0 0116.498 0 .75.75 0 01-.437.695A18.683 18.683 0 0112 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 01-.437-.695z" clip-rule="evenodd" />
              </svg>
            </div>
            <div>
              <p class="font-bold text-white text-sm">Soporte Técnico</p>
              <p class="text-white/80 text-[10px] flex items-center gap-1">
                <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span> En línea
              </p>
            </div>
          </div>
          <button id="close-help-chat" class="p-2 text-white/80 hover:text-white spring-transition cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
              <path fill-rule="evenodd" d="M5.47 5.47a.75.75 0 011.06 0L12 10.94l5.47-5.47a.75.75 0 111.06 1.06L13.06 12l5.47 5.47a.75.75 0 11-1.06 1.06L12 13.06l-5.47 5.47a.75.75 0 01-1.06-1.06L10.94 12 5.47 6.53a.75.75 0 010-1.06z" clip-rule="evenodd" />
            </svg>
          </button>
        </div>
        
        <!-- Messages Area -->
        <div class="flex-1 p-4 overflow-y-auto space-y-4 no-scrollbar bg-white/5">
          <div class="flex justify-start">
            <div class="max-w-[80%] bg-white/10 p-3 rounded-2xl rounded-tl-none border border-white/5 shadow-sm">
              <p class="text-xs text-white/90 leading-relaxed">
                ¡Hola! 👋 Soy tu asesor técnico de SmartMatch. ¿En qué puedo ayudarte hoy?
              </p>
              <p class="text-[9px] text-white/40 mt-1">19:17</p>
            </div>
          </div>
        </div>
        
        <!-- Input Area -->
        <div class="p-4 border-t border-white/10 bg-white/5">
          <div class="relative flex items-center">
            <input type="text" placeholder="Escribe tu duda aquí..." class="w-full bg-white/10 border border-white/20 rounded-full py-3 px-5 text-xs text-white outline-none focus:border-[#FF8300]/50 spring-transition placeholder:text-white/30" />
            <button class="absolute right-2 p-2 text-[#FF8300] hover:text-[#FF8300]/80 spring-transition cursor-pointer">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                <path d="M3.478 2.405a.75.75 0 00-.926.94l2.432 7.905H13.5a.75.75 0 010 1.5H4.984l-2.432 7.905a.75.75 0 00.926.94 60.519 60.519 0 0018.445-8.986.75.75 0 000-1.218A60.517 60.517 0 003.478 2.405z" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
    <!-- It's a Match! Modal -->
    <div id="match-modal" class="fixed inset-0 z-[100] bg-[#010146]/95 backdrop-blur-xl flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
      <div class="flex flex-col items-center justify-center p-6 w-full max-w-sm scale-90 transition-transform duration-500 overflow-y-auto max-h-[90vh]" id="match-content">
        
        <!-- Avatars Facing Each Other -->
        <div class="flex items-center justify-center gap-4 mb-6">
          <!-- Company Logo -->
          <div class="w-20 h-20 rounded-2xl border-2 border-[#FF8300] shadow-[0_0_15px_rgba(255,131,0,0.4)] overflow-hidden bg-white/10 p-1">
            <img src="https://images.unsplash.com/photo-1560179707-f14e90ef3623?w=150&h=150&fit=crop" class="w-full h-full object-cover rounded-xl" />
          </div>
          
          <!-- Spark Icon -->
          <div class="w-8 h-8 rounded-full flex items-center justify-center text-[#FF8300] z-10 -mx-2 drop-shadow-[0_0_8px_rgba(255,131,0,0.6)]">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8">
              <path fill-rule="evenodd" d="M14.615 1.595a.75.75 0 01.359.852L12.982 9.75h7.268a.75.75 0 01.548 1.262l-10.5 11.25a.75.75 0 01-1.272-.71l1.992-7.302H3.75a.75.75 0 01-.548-1.262l10.5-11.25a.75.75 0 01.913-.143z" clip-rule="evenodd" />
            </svg>
          </div>
          
          <!-- User Avatar -->
          <div class="w-20 h-20 rounded-full border-2 border-[#FF8300] shadow-[0_0_15px_rgba(255,131,0,0.4)] overflow-hidden bg-white/10">
            <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=150&auto=format&fit=crop" class="w-full h-full object-cover" />
          </div>
        </div>

        <h2 class="text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#FF8300] to-yellow-400 mb-2 italic drop-shadow-md text-center">
          ¡Es un Match!
        </h2>
        
        <p class="text-sm text-white/70 text-center mb-8 px-4 leading-relaxed">
          Ambas partes están interesadas. Al aceptar, podrán escribirse mensajes directos.
        </p>
        
        <div class="w-full space-y-2">
          <button id="btn-accept-match" class="w-full py-4 bg-[#FF8300] rounded-full text-white font-bold text-lg spring-transition active:scale-95 shadow-[0_0_20px_rgba(255,131,0,0.4)] cursor-pointer">
            Aceptar coincidencia
          </button>
          <button id="btn-reject-match" class="w-full py-3 text-white/50 text-sm font-semibold text-center hover:text-white bg-transparent border-none spring-transition cursor-pointer">
            Rechazar
          </button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    // === Toast Utility ===


    // === Toast Triggers ===
    // TopBar buttons
    document.getElementById('btn-notifications')?.addEventListener('click', () => {
      window.showToast('Notificaciones próximamente disponible');
    });
    document.getElementById('btn-matches-counter')?.addEventListener('click', () => {
      window.showToast('Tus matches próximamente disponible');
    });

    // BottomNav toast links
    document.querySelectorAll('[data-toast]').forEach(el => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        window.showToast((el as HTMLElement).dataset.toast || 'Funcionalidad próximamente disponible');
      });
    });

    // Match modal handling
    const btnAcceptMatch = document.getElementById('btn-accept-match');
    const btnRejectMatch = document.getElementById('btn-reject-match');
    const homeHelpBtn = document.getElementById('home-help-btn');
    const helpChatModal = document.getElementById('help-chat-modal');
    const helpChatContent = document.getElementById('help-chat-content');
    const closeHelpChat = document.getElementById('close-help-chat');
    
    homeHelpBtn?.addEventListener('click', () => {
      helpChatModal?.classList.remove('opacity-0', 'pointer-events-none');
      setTimeout(() => {
        helpChatContent?.classList.remove('scale-95');
        helpChatContent?.classList.add('scale-100');
      }, 50);
    });

    closeHelpChat?.addEventListener('click', () => {
      helpChatModal?.classList.add('opacity-0', 'pointer-events-none');
      helpChatContent?.classList.add('scale-95');
      helpChatContent?.classList.remove('scale-100');
    });
    
    btnAcceptMatch?.addEventListener('click', () => {
      window.showToast('Cargando detalles...');
      setTimeout(() => {
        window.location.href = '/match-detail';
      }, 500);
    });
    
    btnRejectMatch?.addEventListener('click', () => {
      hideMatchModal();
    });

    // === Existing Card Logic ===
    const topCard = document.querySelector('.company-card-wrapper[style*="z-index: 30"]') as HTMLElement;
    const innerCard = topCard?.querySelector('.company-card') as HTMLElement;
    
    // Buttons
    const btnPass = document.getElementById('btn-pass');
    const btnMatch = document.getElementById('btn-match');
    
    // Modal
    const matchModal = document.getElementById('match-modal');
    const matchContent = document.getElementById('match-content');
    
    let isDragging = false;
    let startX = 0;
    
    const showMatchModal = () => {
      matchModal.classList.remove('opacity-0', 'pointer-events-none');
      setTimeout(() => {
        matchContent.classList.remove('scale-90');
        matchContent.classList.add('scale-100');
      }, 50);
    };

    const hideMatchModal = () => {
      matchModal.classList.add('opacity-0', 'pointer-events-none');
      matchContent.classList.add('scale-90');
      matchContent.classList.remove('scale-100');
    };


    const swipeLeft = () => {
      if (!innerCard) return;
      innerCard.classList.add('swipe-left');
      topCard.style.transform = 'translate(-120%, 20px) rotate(-15deg)';
      topCard.style.opacity = '0';
      
      setTimeout(() => {
        innerCard.classList.remove('swipe-left');
        topCard.style.transform = 'translate(0, 0) rotate(0deg)';
        topCard.style.opacity = '1';
      }, 800);
    };

    const swipeRight = () => {
      if (!innerCard) return;
      innerCard.classList.add('swipe-right');
      topCard.style.transform = 'translate(120%, 20px) rotate(15deg)';
      topCard.style.opacity = '0';
      
      setTimeout(() => {
        showMatchModal();
        setTimeout(() => {
          innerCard.classList.remove('swipe-right');
          topCard.style.transform = 'translate(0, 0) rotate(0deg)';
          topCard.style.opacity = '1';
        }, 300);
      }, 400);
    };

    if (btnPass) btnPass.addEventListener('click', swipeLeft);
    if (btnMatch) btnMatch.addEventListener('click', swipeRight);

    // Touch/drag
    if (topCard) {
      topCard.addEventListener('mousedown', (e) => {
        isDragging = true;
        startX = e.clientX;
        topCard.style.transition = 'none';
      });

      document.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        const deltaX = e.clientX - startX;
        const rotation = deltaX * 0.05;
        
        topCard.style.transform = `translate(${deltaX}px, 0) rotate(${rotation}deg)`;
        
        if (deltaX > 50) {
          innerCard.classList.add('swipe-right');
          innerCard.classList.remove('swipe-left');
        } else if (deltaX < -50) {
          innerCard.classList.add('swipe-left');
          innerCard.classList.remove('swipe-right');
        } else {
          innerCard.classList.remove('swipe-left', 'swipe-right');
        }
      });

      document.addEventListener('mouseup', (e) => {
        if (!isDragging) return;
        isDragging = false;
        topCard.style.transition = 'all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)';
        
        const deltaX = e.clientX - startX;
        
        if (deltaX > 100) {
          swipeRight();
        } else if (deltaX < -100) {
          swipeLeft();
        } else {
          topCard.style.transform = 'translate(0, 0) rotate(0deg)';
          innerCard.classList.remove('swipe-left', 'swipe-right');
        }
      });
      
      // Touch events
      topCard.addEventListener('touchstart', (e) => {
        isDragging = true;
        startX = e.touches[0].clientX;
        topCard.style.transition = 'none';
      }, {passive: true});
      
      document.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        const deltaX = e.touches[0].clientX - startX;
        const rotation = deltaX * 0.05;
        topCard.style.transform = `translate(${deltaX}px, 0) rotate(${rotation}deg)`;
        
        if (deltaX > 50) {
          innerCard.classList.add('swipe-right');
          innerCard.classList.remove('swipe-left');
        } else if (deltaX < -50) {
          innerCard.classList.add('swipe-left');
          innerCard.classList.remove('swipe-right');
        } else {
          innerCard.classList.remove('swipe-left', 'swipe-right');
        }
      }, {passive: true});
      
      document.addEventListener('touchend', (e) => {
        if (!isDragging) return;
        isDragging = false;
        topCard.style.transition = 'all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)';
        
        const endX = e.changedTouches[0].clientX;
        const deltaX = endX - startX;
        
        if (deltaX > 100) {
          swipeRight();
        } else if (deltaX < -100) {
          swipeLeft();
        } else {
          topCard.style.transform = 'translate(0, 0) rotate(0deg)';
          innerCard.classList.remove('swipe-left', 'swipe-right');
        }
      });
    }
  });
</script>

