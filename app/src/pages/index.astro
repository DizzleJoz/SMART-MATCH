---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import BottomNav from '../components/BottomNav.astro';
import CompanySwipeCard from '../components/CompanySwipeCard.astro';

// Sample data for company cards
const companies = [
  {
    companyName: "TechNova Inc.",
    sector: "Fintech",
    size: "50-200 personas",
    description: "Estamos revolucionando los pagos B2B. Buscamos talento apasionado por resolver problemas complejos con código limpio y escalable.",
    benefits: ["Trabajo remoto", "Equity", "Horario flexible"],
    matchScore: 94,
    logoImage: "https://images.unsplash.com/photo-1560179707-f14e90ef3623?w=150&h=150&fit=crop",
    coverImage: "https://images.unsplash.com/photo-1497366216548-37526070297c?w=600&h=400&fit=crop"
  },
  {
    companyName: "Luminary Studios",
    sector: "Agencia Creativa",
    size: "10-50 personas",
    description: "Creamos experiencias digitales galardonadas. Cultura relajada, enfocada en la creatividad y el diseño centrado en el usuario.",
    benefits: ["Oficina pet-friendly", "Viernes cortos", "Bonos"],
    matchScore: 88,
    logoImage: "https://images.unsplash.com/photo-1572044162444-ad60f128bdea?w=150&h=150&fit=crop",
    coverImage: "https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=600&h=400&fit=crop"
  },
  {
    companyName: "EcoLogistics",
    sector: "Green Tech",
    size: "200-500 personas",
    description: "Optimizamos la cadena de suministro global para reducir emisiones de carbono. Únete a nuestra misión por un futuro sostenible.",
    benefits: ["Seguro médico", "Remoto opcional", "Stock"],
    matchScore: 82,
    logoImage: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=150&h=150&fit=crop",
    coverImage: "https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=600&h=400&fit=crop"
  }
];
---

<Layout title="JobMatch | Descubre Empresas">
  <div class="relative w-full h-full flex flex-col bg-transparent overflow-hidden touch-none">
    
    <TopBar />

    <!-- Cards Stack -->
    <main class="flex-1 relative w-full flex items-center justify-center overflow-hidden" id="card-stack">
      {/* Render cards in reverse order */}
      <CompanySwipeCard 
        {...companies[2]}
        isThird={true}
      />
      <CompanySwipeCard 
        {...companies[1]}
        isSecond={true}
      />
      <CompanySwipeCard 
        {...companies[0]}
        isTop={true}
      />
    </main>

    <!-- Action Buttons -->
    <div class="absolute bottom-28 left-0 right-0 flex items-center justify-center gap-8 px-8 z-40 pointer-events-none">
      
      <!-- Reject (Swipe Left) -->
      <button id="btn-pass" class="w-20 h-20 rounded-full bg-white/10 border-2 border-white flex items-center justify-center text-white spring-transition hover:scale-[1.12] active:scale-[1.12] active:shadow-[0_0_20px_rgba(255,60,60,0.35)] pointer-events-auto backdrop-blur-md cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-8 h-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Match (Swipe Right) -->
      <button id="btn-match" class="w-20 h-20 rounded-full bg-[#FF8300] flex items-center justify-center text-white spring-transition hover:scale-[1.12] active:scale-[1.12] active:shadow-[0_0_20px_rgba(255,131,0,0.45)] pointer-events-auto shadow-lg cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-9 h-9">
          <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z" />
        </svg>
      </button>
      
    </div>

    <BottomNav activeTab="home" />
    
    <!-- It's a Match! Modal -->
    <div id="match-modal" class="fixed inset-0 z-[100] bg-[#010146]/95 backdrop-blur-xl flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
      <div class="flex flex-col items-center justify-center p-6 w-full max-w-sm scale-90 transition-transform duration-500 overflow-y-auto max-h-[90vh]" id="match-content">
        
        <h2 class="text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#FF8300] to-yellow-400 mb-6 italic drop-shadow-md">
          ¡Es un Match!
        </h2>
        
        <!-- Job Title (Primary) -->
        <h3 class="text-2xl font-black text-white text-center mb-3 leading-tight">
          Diseñadora UX/UI Senior
        </h3>
        
        <!-- Job Description (Secondary) -->
        <div class="w-full glass-card p-4 mb-4 border border-white/10">
          <div class="space-y-2 text-sm">
            <div class="flex items-center gap-2 text-white/80">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-[#FF8300] shrink-0">
                <path fill-rule="evenodd" d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 00.281-.14c.186-.096.446-.24.757-.433a19.695 19.695 0 002.682-2.282c1.944-1.99 3.946-4.948 3.946-8.567A6.5 6.5 0 0010 1a6.5 6.5 0 00-6.5 7.5c0 3.62 2.002 6.578 3.946 8.567a19.695 19.695 0 002.682 2.282 16.383 16.383 0 001.038.573l.018.008.006.003zM10 10a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
              </svg>
              <span>Remoto · Bogotá, Colombia</span>
            </div>
            <div class="flex items-center gap-2 text-white/80">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-[#FF8300] shrink-0">
                <path d="M10.75 10.818a.75.75 0 01-1.5 0V7.75a.75.75 0 011.5 0v3.068zM10 14a1 1 0 100-2 1 1 0 000 2z" />
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
              </svg>
              <span>Tiempo completo · $3.5M - $5M COP</span>
            </div>
          </div>
        </div>

        <!-- Requirements Tags -->
        <div class="flex flex-wrap gap-2 justify-center mb-6">
          <span class="px-3 py-1.5 bg-[#FF8300]/15 border border-[#FF8300]/30 text-[#FF8300] text-xs font-bold rounded-lg">3+ años experiencia</span>
          <span class="px-3 py-1.5 bg-[#FF8300]/15 border border-[#FF8300]/30 text-[#FF8300] text-xs font-bold rounded-lg">Figma & Prototyping</span>
          <span class="px-3 py-1.5 bg-[#FF8300]/15 border border-[#FF8300]/30 text-[#FF8300] text-xs font-bold rounded-lg">Inglés B2</span>
        </div>

        <!-- Company Info (Tertiary - smaller) -->
        <div class="flex items-center gap-3 mb-8 px-4 py-3 glass-card border border-white/10 w-full">
          <div class="w-10 h-10 rounded-xl overflow-hidden bg-white/10 shrink-0 border border-white/15">
            <img src="https://images.unsplash.com/photo-1560179707-f14e90ef3623?w=150&h=150&fit=crop" class="w-full h-full object-cover" />
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-white font-bold text-sm truncate">TechNova Inc.</p>
            <p class="text-white/55 text-xs">Fintech · 50-200 personas</p>
          </div>
          <div class="flex items-center gap-1 bg-[#FF8300]/15 px-2 py-1 rounded-lg">
            <span class="text-[#FF8300] font-bold text-xs">94%</span>
          </div>
        </div>
        
        <!-- Avatars -->
        <div class="flex items-center justify-center gap-4 mb-8">
          <div class="w-16 h-16 rounded-full border-[3px] border-[#FF8300] shadow-[0_0_15px_rgba(255,131,0,0.4)] overflow-hidden bg-white/10">
            <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=150&h=150&fit=crop" class="w-full h-full object-cover" />
          </div>
          
          <div class="w-8 h-8 rounded-full bg-[#FF8300] flex items-center justify-center text-white shadow-[0_0_12px_rgba(255,131,0,0.5)] z-10 -mx-4">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
              <path fill-rule="evenodd" d="M15.22 3.22a.75.75 0 011.06 0l4.5 4.5a.75.75 0 010 1.06l-4.5 4.5a.75.75 0 11-1.06-1.06l3.22-3.22H5.25a.75.75 0 010-1.5h13.19l-3.22-3.22a.75.75 0 010-1.06zM8.78 20.78a.75.75 0 01-1.06 0l-4.5-4.5a.75.75 0 010-1.06l4.5-4.5a.75.75 0 111.06 1.06L5.56 15h13.19a.75.75 0 010 1.5H5.56l3.22 3.22a.75.75 0 010 1.06z" clip-rule="evenodd" />
            </svg>
          </div>
          
          <div class="w-16 h-16 rounded-full border-[3px] border-[#FF8300] shadow-[0_0_15px_rgba(255,131,0,0.4)] overflow-hidden bg-white/10 flex items-center justify-center">
            <img src="https://images.unsplash.com/photo-1560179707-f14e90ef3623?w=150&h=150&fit=crop" class="w-full h-full object-cover p-0.5 rounded-full" />
          </div>
        </div>
        
        <div class="w-full space-y-3">
          <button id="btn-close-match" class="btn-primary w-full py-4 text-lg">
            ¡Increíble!
          </button>
          <button id="btn-view-company" class="w-full py-4 rounded-full text-white/60 font-semibold hover:bg-white/10 spring-transition active:scale-95 cursor-pointer">
            Ver empresa
          </button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    // === Toast Utility ===
    const showToast = (message: string) => {
      // Remove existing toast
      document.querySelector('.toast')?.remove();
      const toast = document.createElement('div');
      toast.className = 'toast';
      toast.textContent = message;
      document.body.appendChild(toast);
      setTimeout(() => {
        toast.classList.add('toast-out');
        setTimeout(() => toast.remove(), 300);
      }, 2500);
    };

    // === Toast Triggers ===
    // TopBar buttons
    document.getElementById('btn-notifications')?.addEventListener('click', () => {
      showToast('Notificaciones próximamente disponible');
    });
    document.getElementById('btn-matches-counter')?.addEventListener('click', () => {
      showToast('Tus matches próximamente disponible');
    });

    // BottomNav toast links
    document.querySelectorAll('[data-toast]').forEach(el => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        showToast((el as HTMLElement).dataset.toast || 'Funcionalidad próximamente disponible');
      });
    });

    // Match modal: "Ver empresa"
    document.getElementById('btn-view-company')?.addEventListener('click', () => {
      showToast('Detalle de empresa próximamente disponible');
    });

    // === Existing Card Logic ===
    const topCard = document.querySelector('.company-card-wrapper[style*="z-index: 30"]') as HTMLElement;
    const innerCard = topCard?.querySelector('.company-card') as HTMLElement;
    
    // Buttons
    const btnPass = document.getElementById('btn-pass');
    const btnMatch = document.getElementById('btn-match');
    
    // Modal
    const matchModal = document.getElementById('match-modal');
    const matchContent = document.getElementById('match-content');
    const btnCloseMatch = document.getElementById('btn-close-match');
    
    let isDragging = false;
    let startX = 0;
    
    const showMatchModal = () => {
      matchModal.classList.remove('opacity-0', 'pointer-events-none');
      setTimeout(() => {
        matchContent.classList.remove('scale-90');
        matchContent.classList.add('scale-100');
      }, 50);
    };

    const hideMatchModal = () => {
      matchModal.classList.add('opacity-0', 'pointer-events-none');
      matchContent.classList.add('scale-90');
      matchContent.classList.remove('scale-100');
    };

    if (btnCloseMatch) {
      btnCloseMatch.addEventListener('click', hideMatchModal);
    }

    const swipeLeft = () => {
      if (!innerCard) return;
      innerCard.classList.add('swipe-left');
      topCard.style.transform = 'translate(-120%, 20px) rotate(-15deg)';
      topCard.style.opacity = '0';
      
      setTimeout(() => {
        innerCard.classList.remove('swipe-left');
        topCard.style.transform = 'translate(0, 0) rotate(0deg)';
        topCard.style.opacity = '1';
      }, 800);
    };

    const swipeRight = () => {
      if (!innerCard) return;
      innerCard.classList.add('swipe-right');
      topCard.style.transform = 'translate(120%, 20px) rotate(15deg)';
      topCard.style.opacity = '0';
      
      setTimeout(() => {
        showMatchModal();
        setTimeout(() => {
          innerCard.classList.remove('swipe-right');
          topCard.style.transform = 'translate(0, 0) rotate(0deg)';
          topCard.style.opacity = '1';
        }, 300);
      }, 400);
    };

    if (btnPass) btnPass.addEventListener('click', swipeLeft);
    if (btnMatch) btnMatch.addEventListener('click', swipeRight);

    // Touch/drag
    if (topCard) {
      topCard.addEventListener('mousedown', (e) => {
        isDragging = true;
        startX = e.clientX;
        topCard.style.transition = 'none';
      });

      document.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        const deltaX = e.clientX - startX;
        const rotation = deltaX * 0.05;
        
        topCard.style.transform = `translate(${deltaX}px, 0) rotate(${rotation}deg)`;
        
        if (deltaX > 50) {
          innerCard.classList.add('swipe-right');
          innerCard.classList.remove('swipe-left');
        } else if (deltaX < -50) {
          innerCard.classList.add('swipe-left');
          innerCard.classList.remove('swipe-right');
        } else {
          innerCard.classList.remove('swipe-left', 'swipe-right');
        }
      });

      document.addEventListener('mouseup', (e) => {
        if (!isDragging) return;
        isDragging = false;
        topCard.style.transition = 'all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)';
        
        const deltaX = e.clientX - startX;
        
        if (deltaX > 100) {
          swipeRight();
        } else if (deltaX < -100) {
          swipeLeft();
        } else {
          topCard.style.transform = 'translate(0, 0) rotate(0deg)';
          innerCard.classList.remove('swipe-left', 'swipe-right');
        }
      });
      
      // Touch events
      topCard.addEventListener('touchstart', (e) => {
        isDragging = true;
        startX = e.touches[0].clientX;
        topCard.style.transition = 'none';
      }, {passive: true});
      
      document.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        const deltaX = e.touches[0].clientX - startX;
        const rotation = deltaX * 0.05;
        topCard.style.transform = `translate(${deltaX}px, 0) rotate(${rotation}deg)`;
        
        if (deltaX > 50) {
          innerCard.classList.add('swipe-right');
          innerCard.classList.remove('swipe-left');
        } else if (deltaX < -50) {
          innerCard.classList.add('swipe-left');
          innerCard.classList.remove('swipe-right');
        } else {
          innerCard.classList.remove('swipe-left', 'swipe-right');
        }
      }, {passive: true});
      
      document.addEventListener('touchend', (e) => {
        if (!isDragging) return;
        isDragging = false;
        topCard.style.transition = 'all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)';
        
        const endX = e.changedTouches[0].clientX;
        const deltaX = endX - startX;
        
        if (deltaX > 100) {
          swipeRight();
        } else if (deltaX < -100) {
          swipeLeft();
        } else {
          topCard.style.transform = 'translate(0, 0) rotate(0deg)';
          innerCard.classList.remove('swipe-left', 'swipe-right');
        }
      });
    }
  });
</script>

