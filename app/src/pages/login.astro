---
import Layout from '../layouts/Layout.astro';
---

<Layout title="JobMatch | Inicia sesión">
  <div class="relative w-full h-full flex flex-col bg-transparent">
    
    <!-- Top Illustration / Branding -->
    <div class="flex-1 flex flex-col items-center justify-center p-8 relative overflow-hidden">
      <!-- Decorative background circles -->
      <div class="absolute -top-20 -right-20 w-64 h-64 bg-[#FF8300] rounded-full mix-blend-screen filter blur-[100px] opacity-20"></div>
      <div class="absolute -bottom-20 -left-20 w-64 h-64 bg-[#FF8300] rounded-full mix-blend-screen filter blur-[100px] opacity-20"></div>
      
      <div class="relative z-10 flex flex-col items-center">
        <!-- Logo -->
        <div class="mb-16 animate-logo-in">
          <img src="/1x/Recurso 1.png" alt="JobMatch Logo" class="h-52 w-auto drop-shadow-[0_0_50px_rgba(255,131,0,0.4)]" />
        </div>
        <h1 class="sr-only">JobMatch</h1>
        <p class="text-white/75 text-center font-medium px-4 text-lg">
          Haz match con las mejores empresas y encuentra tu trabajo ideal.
        </p>
      </div>
    </div>
    
    <!-- Auth Buttons Area -->
    <div class="glass-card rounded-b-none border-b-0 relative z-20 px-6 pt-10 pb-8 flex flex-col gap-4">
      
      <div class="w-12 h-1.5 bg-white/20 rounded-full mx-auto absolute top-4 left-1/2 -translate-x-1/2"></div>
      
      <p class="text-sm font-semibold text-white/60 text-center uppercase tracking-wider mb-2">Continúa con</p>
      
      <!-- Google Button -->
      <a href="/role" class="w-full btn-primary py-4 px-6 gap-3">
        <svg viewBox="0 0 24 24" class="w-6 h-6 bg-white rounded-full p-1" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <span>Google</span>
      </a>

      <!-- LinkedIn Button -->
      <a href="/role" class="w-full glass-input flex items-center justify-center gap-3 font-semibold py-4 px-6 hover:bg-white/10 active:scale-[0.98]">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-[#0A66C2]">
          <path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"></path>
        </svg>
        <span>LinkedIn</span>
      </a>

      <!-- Email Button -->
      <a href="/role" class="w-full glass-input flex items-center justify-center gap-3 font-semibold py-4 px-6 hover:bg-white/10 active:scale-[0.98]">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-white">
          <path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z" />
          <path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z" />
        </svg>
        <span>Correo electrónico</span>
      </a>
      
      <!-- Terms Text -->
      <p class="text-[11px] text-center text-white/55 mt-6 max-w-[280px] mx-auto leading-relaxed">
        Al continuar, aceptas nuestros <a href="#" class="text-[#FF8300] font-bold hover:underline">Términos</a> y <a href="#" class="text-[#FF8300] font-bold hover:underline">Política de privacidad</a>.
      </p>
      
    </div>
  </div>
</Layout>
