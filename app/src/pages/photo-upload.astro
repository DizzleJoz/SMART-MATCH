---
import Layout from '../layouts/Layout.astro';
---

<Layout title="JobMatch | Agrega tu foto">
  <div class="relative w-full h-full flex flex-col bg-transparent overflow-hidden">
    
    <!-- Top Bar with Progress -->
    <div class="px-6 pt-12 pb-4 z-10">
      <div class="flex items-center justify-between mb-4">
        <a href="/profile-setup" class="p-3 -ml-3 text-white hover:text-white/70 spring-transition" style="min-width: 44px; min-height: 44px; display: inline-flex; align-items: center; justify-content: center;">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
          </svg>
        </a>
        <img src="/1x/Recurso 1.png" alt="JobMatch Logo" class="h-14 w-auto drop-shadow-md" />
        <div class="w-[44px]"></div> <!-- Spacer for center alignment -->
      </div>
      <!-- Progress Bar and Step -->
      <div class="flex justify-between items-center mb-2">
        <span class="text-[#FF8300] font-bold text-xs tracking-widest uppercase">Paso 3 de 3</span>
      </div>
      <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden">
        <div class="w-full h-full bg-[#FF8300] rounded-full shadow-[0_0_10px_rgba(255,131,0,0.8)]"></div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="flex-1 flex flex-col items-center justify-center px-6 pb-48">
      
      <!-- Header -->
      <div class="text-center mb-10">
        <h1 class="text-2xl font-black text-white mb-3 drop-shadow-sm">Completa tu perfil</h1>
        <p class="text-white/75 text-sm leading-relaxed max-w-[280px] mx-auto">
          Agrega una foto para que los reclutadores te reconozcan fácilmente.
        </p>
      </div>

      <!-- Photo Circle Placeholder -->
      <div class="relative mb-8">
        <!-- Glowing ring -->
        <div class="absolute -inset-3 rounded-full bg-[#FF8300]/10 blur-xl"></div>
        
        <div id="photo-preview" class="relative w-40 h-40 rounded-full bg-white/5 border-2 border-dashed border-white/20 flex flex-col items-center justify-center gap-3 overflow-hidden backdrop-blur-md shadow-[0_0_30px_rgba(255,131,0,0.1)] spring-transition hover:border-[#FF8300]/50 cursor-pointer group">
          <!-- Camera Icon -->
          <div id="photo-placeholder" class="flex flex-col items-center gap-3">
            <div class="w-16 h-16 rounded-full bg-white/10 flex items-center justify-center group-hover:bg-[#FF8300]/20 spring-transition">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8 text-white/40 group-hover:text-[#FF8300] spring-transition">
                <path d="M12 9a3.75 3.75 0 100 7.5A3.75 3.75 0 0012 9z" />
                <path fill-rule="evenodd" d="M9.344 3.071a49.52 49.52 0 015.312 0c.967.052 1.83.585 2.332 1.39l.821 1.317c.24.383.645.643 1.11.71.386.054.77.113 1.152.177 1.432.239 2.429 1.493 2.429 2.909V18a3 3 0 01-3 3h-15a3 3 0 01-3-3V9.574c0-1.416.997-2.67 2.429-2.909.382-.064.766-.123 1.151-.178a1.56 1.56 0 001.11-.71l.822-1.315a2.942 2.942 0 012.332-1.39zM6.75 12.75a5.25 5.25 0 1110.5 0 5.25 5.25 0 01-10.5 0zm12-1.5a.75.75 0 100-1.5.75.75 0 000 1.5z" clip-rule="evenodd" />
              </svg>
            </div>
            <span class="text-xs text-white/40 font-medium">Toca para agregar</span>
          </div>
          <!-- Hidden preview image -->
          <img id="preview-img" src="" alt="Vista previa" class="absolute inset-0 w-full h-full object-cover hidden" />
        </div>
      </div>

      <!-- Motivational Message -->
      <div class="flex items-center gap-2 mb-10 px-4 py-3 bg-[#FF8300]/10 rounded-2xl border border-[#FF8300]/20 max-w-[320px]">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-[#FF8300] shrink-0">
          <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
        </svg>
        <p class="text-white/80 text-xs font-medium leading-relaxed">
          Los perfiles con foto reciben <span class="text-[#FF8300] font-bold">3x más atención</span> de los reclutadores.
        </p>
      </div>

      <!-- Upload Buttons -->
      <div class="w-full max-w-[320px] space-y-3">
        <button id="btn-upload-gallery" class="btn-primary w-full py-4 gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
            <path fill-rule="evenodd" d="M1.5 6a2.25 2.25 0 012.25-2.25h16.5A2.25 2.25 0 0122.5 6v12a2.25 2.25 0 01-2.25 2.25H3.75A2.25 2.25 0 011.5 18V6zM3 16.06V18c0 .414.336.75.75.75h16.5A.75.75 0 0021 18v-1.94l-2.69-2.689a1.5 1.5 0 00-2.12 0l-.88.879.97.97a.75.75 0 11-1.06 1.06l-5.16-5.159a1.5 1.5 0 00-2.12 0L3 16.061zm10.125-7.81a1.125 1.125 0 112.25 0 1.125 1.125 0 01-2.25 0z" clip-rule="evenodd" />
          </svg>
          <span>Subir foto desde galería</span>
        </button>
        

      </div>

    </div>

    <!-- Skip Link -->
    <div class="absolute bottom-12 left-0 right-0 text-center z-20">
      <a href="/" class="text-white/50 text-sm font-medium hover:text-white/70 spring-transition">
        Ahora no, completar después
      </a>
    </div>

  </div>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const btnGallery = document.getElementById('btn-upload-gallery');
    const photoPreview = document.getElementById('photo-preview');
    const previewImg = document.getElementById('preview-img') as HTMLImageElement;
    const placeholder = document.getElementById('photo-placeholder');
    
    // Hidden file input for gallery
    const fileInput = document.createElement('input');
    fileInput.type = 'file';
    fileInput.accept = 'image/*';
    fileInput.style.display = 'none';
    document.body.appendChild(fileInput);



    const handleFileSelect = (file: File) => {
      const reader = new FileReader();
      reader.onload = (e) => {
        if (previewImg && placeholder && e.target?.result) {
          previewImg.src = e.target.result as string;
          previewImg.classList.remove('hidden');
          placeholder.classList.add('hidden');
          
          // Change border style
          photoPreview?.classList.remove('border-dashed', 'border-white/20');
          photoPreview?.classList.add('border-solid', 'border-[#FF8300]');
        }
      };
      reader.readAsDataURL(file);
    };

    fileInput.addEventListener('change', (e) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (file) handleFileSelect(file);
    });



    btnGallery?.addEventListener('click', () => fileInput.click());
    photoPreview?.addEventListener('click', () => fileInput.click());
  });
</script>
