---
const { activeTab = 'home' } = Astro.props;
---

<nav class="absolute bottom-0 left-0 right-0 z-50 bg-[#010146]/85 backdrop-blur-[12px] border-t border-white/10 pb-8 pt-4 px-6">
  <ul class="flex items-center justify-between max-w-md mx-auto">
    
    <!-- Inicio (Swipe) -->
    <li>
      <a href="/" class={`flex flex-col items-center justify-center p-2 min-w-[64px] spring-transition active:scale-95 group ${activeTab === 'home' ? 'text-[#FF8300]' : 'text-white/55 hover:text-white/70'}`}>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 mb-1 group-hover:-translate-y-0.5 spring-transition">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
        </svg>
        <span class="text-[9px] font-bold uppercase tracking-wider">Inicio</span>
      </a>
    </li>
    
    <!-- Coincidencias -->
    <li>
      <a href="#" id="nav-matches" data-toast="Matches próximamente disponible" class={`flex flex-col items-center justify-center p-2 min-w-[64px] spring-transition active:scale-95 group ${activeTab === 'matches' ? 'text-[#FF8300]' : 'text-white/55 hover:text-white/70'}`}>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 mb-1 group-hover:-translate-y-0.5 spring-transition">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
        </svg>
        <span class="text-[9px] font-bold uppercase tracking-wider">Matches</span>
      </a>
    </li>
    
    <!-- Mensajes -->
    <li>
      <a href="#" id="nav-messages" data-toast="Mensajes próximamente disponible" class={`flex flex-col items-center justify-center p-2 min-w-[64px] spring-transition active:scale-95 group ${activeTab === 'messages' ? 'text-[#FF8300]' : 'text-white/55 hover:text-white/70'}`}>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 mb-1 group-hover:-translate-y-0.5 spring-transition">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
        </svg>
        <span class="text-[9px] font-bold uppercase tracking-wider">Mensajes</span>
      </a>
    </li>
    
    <!-- Perfil (con avatar del usuario) -->
    <li>
      <a href="/profile-setup" class={`flex flex-col items-center justify-center p-2 min-w-[64px] spring-transition active:scale-95 group ${activeTab === 'profile' ? 'text-[#FF8300]' : 'text-white/55 hover:text-white/70'}`}>
        <div class={`w-6 h-6 mb-1 rounded-full overflow-hidden group-hover:-translate-y-0.5 spring-transition border-2 ${activeTab === 'profile' ? 'border-[#FF8300]' : 'border-white/30'}`}>
          <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=150&auto=format&fit=crop" alt="Mi perfil" class="w-full h-full object-cover" />
        </div>
        <span class="text-[9px] font-bold uppercase tracking-wider">Perfil</span>
      </a>
    </li>
    
  </ul>
</nav>
