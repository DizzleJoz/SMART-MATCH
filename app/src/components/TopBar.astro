---
---

<header class="absolute top-0 left-0 right-0 z-50 px-6 pt-12 pb-4 flex items-center justify-between bg-[#010146]/80 backdrop-blur-md">
  <!-- Logo -->
  <div class="flex-1">
    <img src="/1x/Recurso 1.png" alt="JobMatch Logo" class="h-14 md:h-16 w-auto drop-shadow-md" />
    <h1 class="sr-only">JobMatch</h1>
  </div>
  
  <!-- Match Counter -->
  <div id="btn-matches-counter" class="flex items-center justify-center spring-transition cursor-pointer hover:scale-105 active:scale-95">
    <div class="relative flex items-center justify-center w-10 h-10 rounded-full bg-[#FF8300]/10 text-[#FF8300] shadow-[0_0_15px_rgba(255,131,0,0.2)] border border-[#FF8300]/20">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
        <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z" />
      </svg>
      <span class="absolute -top-1 -right-1 flex h-4 w-4 items-center justify-center rounded-full bg-[#FF8300] text-[9px] font-bold text-white shadow-[0_0_10px_rgba(255,131,0,0.8)] border border-[#010146]">
        3
      </span>
    </div>
  </div>
  
  <!-- Right Actions -->
  <div class="flex-1 flex items-center justify-end">
    <button id="btn-notifications" class="relative spring-transition hover:scale-105 active:scale-95 text-white/50 hover:text-white cursor-pointer">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
      </svg>
    </button>
  </div>
</header>
